rules_version = '2';

// FCFC '26 uses Firebase Anonymous Auth so these rules can tell callers apart.
// Every client (and the results poller) silently signs in anonymously; that
// gives each device a stable uid. There is still no "account" — player identity
// is the self-registered roster doc, and PINs remain plaintext (intentional).
// What these rules add: only an arbiter can change results, the arbiter code
// lives server-side (never readable), and writes must be authed + well-shaped.
//
// Paste into Firebase console -> Firestore Database -> Rules -> Publish.
// Prereqs: enable Anonymous sign-in (Authentication -> Sign-in method) and
// create config/arbiter = { code: "<your code>" } BEFORE publishing this.
service cloud.firestore {
  match /databases/{database}/documents {

    // A caller is an arbiter iff they hold an arbiters/<their-uid> doc. Rules
    // run server-side, so this read works even though the collection is closed.
    function isArbiter() {
      return request.auth != null
        && exists(/databases/$(database)/documents/arbiters/$(request.auth.uid));
    }

    // The arbiter secret. Never readable or writable by clients — seed it from
    // the Firebase console only. This is what keeps the code out of the bundle.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Self-service elevation: a caller writes arbiters/<own-uid> with the code,
    // and the rule validates it against the closed config doc server-side. Wrong
    // code -> rejected. The collection is unreadable, so the code can't leak.
    // Callers may remove their own doc to step down (used by the UI and the
    // poller, which cleans itself up after each run).
    match /arbiters/{uid} {
      allow get, list: if false;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.code
             == get(/databases/$(database)/documents/config/arbiter).data.code;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Fixtures: world-readable. Only an arbiter (a human in arbiter mode, or the
    // poller) may create/change them; nobody deletes.
    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isArbiter();
      allow delete: if false;
    }

    // Roster: anyone signed in may register/update a profile; require the full
    // shape so a write can't drop fields or inject junk. No deletes from clients.
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(['id', 'name', 'avatar', 'pin'])
        && request.resource.data.id is string
        && request.resource.data.name is string && request.resource.data.name.size() <= 40
        && request.resource.data.avatar is string && request.resource.data.avatar.size() <= 16
        && request.resource.data.pin is string && request.resource.data.pin.size() <= 8;
      allow delete: if isArbiter();
    }

    // Recent form: world-readable; written only by the form job (arbiter).
    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if isArbiter();
      allow delete: if false;
    }

    // Bets: world-readable (leaderboard + social reveal). Writes require auth and
    // a valid outcome shape; deletes are arbiter-only (the wipe-bets script).
    match /bets/{betId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.pick in ['HOME', 'DRAW', 'AWAY']
        && request.resource.data.locked is bool
        && request.resource.data.user_id is string;
      allow delete: if isArbiter();
    }

    // Web-push subscriptions. Each device, while signed in, registers/removes
    // its own subscription tagged with the player id it's logged in as. Only the
    // sender (the poller, an arbiter) reads them — endpoints are mildly sensitive
    // and nothing in the app needs them client-side. Anyone signed in may delete
    // (user opt-out), and the sender prunes expired ones.
    match /pushSubs/{id} {
      allow read: if isArbiter();
      allow create, update: if request.auth != null
        && request.resource.data.user_id is string
        && request.resource.data.subscription is map;
      allow delete: if request.auth != null;
    }

    // Notification dedup state — what's already been alerted on (match statuses,
    // event counts, ranks, title holders). Written and read only by the sender.
    match /notifyState/{id} {
      allow read, write: if isArbiter();
    }

    // Pro sessions: a player organizes a Pro Clubs meetup, invites others, who
    // accept/reject (rejection carries a "Sebep" reason). World-readable (the Pro
    // tab shows everyone's sessions + responses). Create requires the full shape;
    // updates may only change `responses` (invitees respond) — host/invitees/
    // start/createdAt are frozen, so a responder can't reshape the session.
    // Deletes are arbiter-only (cleanup).
    match /proSessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['id', 'host', 'invitees', 'startMs', 'createdAt', 'responses'])
        && request.resource.data.host is string
        && request.resource.data.invitees is list
        && request.resource.data.startMs is number
        && request.resource.data.createdAt is number
        && request.resource.data.responses is map;
      allow update: if request.auth != null
        && request.resource.data.host == resource.data.host
        && request.resource.data.invitees == resource.data.invitees
        && request.resource.data.startMs == resource.data.startMs
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.responses is map;
      allow delete: if isArbiter();
    }

    // Build-Your-Bracket predictions: world-readable (everyone can view each
    // other's locked bracket). A bracket is written once, locked, and is then
    // permanent — `update` is allowed only while the stored doc is still
    // unlocked, so a locked prediction can never be retconned after results land.
    // Deletes are arbiter-only (reset). Doc id is the player id.
    match /brackets/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['user_id', 'picks', 'locked'])
        && request.resource.data.user_id is string
        && request.resource.data.picks is map
        && request.resource.data.locked is bool;
      allow update: if request.auth != null
        && resource.data.locked == false
        && request.resource.data.picks is map
        && request.resource.data.locked is bool;
      allow delete: if isArbiter();
    }
  }
}
